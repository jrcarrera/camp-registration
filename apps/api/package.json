{
  "name": "@camp-registration/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/server.ts",
    "openapi:write": "tsx src/openapi.ts",
    "predev": "pnpm --filter @camp-registration/contracts build && pnpm --filter @camp-registration/database build",
    "preopenapi:write": "pnpm --filter @camp-registration/contracts build && pnpm --filter @camp-registration/database build",
    "pretest": "pnpm --filter @camp-registration/contracts build && pnpm --filter @camp-registration/database build",
    "start": "node dist/server.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@camp-registration/contracts": "workspace:*",
    "@camp-registration/database": "workspace:*",
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "6.0.0",
    "@fastify/type-provider-typebox": "6.1.0",
    "fastify": "5.8.5"
  }
}
